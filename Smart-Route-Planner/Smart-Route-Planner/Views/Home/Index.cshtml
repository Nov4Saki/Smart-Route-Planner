@{
    ViewData["Title"] = "Select Location";
}

<main class="index-page">

    <div id="map"></div>

    <!-- Top bar -->
    <div id="topbar">
        <div class="brand">
            <div class="brand-dot"></div>
            NestFinder
        </div>
        <span class="badge-tag">LOCATION PICKER</span>
    </div>

    <!-- Instruction pill -->
    <div id="instruction">
        <i class="bi bi-hand-index-thumb"></i>
        Click anywhere on the map to pin your location
    </div>

    <!-- Panel -->
    <div id="panel">
        <div class="panel-header">Selected Location</div>
        <div id="coords-box">
            <div class="coords-icon"><i class="bi bi-geo-alt-fill"></i></div>
            <div>
                <div class="coords-label">Coordinates</div>
                <div id="coords-text"><span class="coords-placeholder">No location selected</span></div>
            </div>
        </div>
        <button id="find-btn" disabled>
            <i class="bi bi-buildings-fill"></i>
            Find Nearby Apartments
        </button>
    </div>

</main>